# Default Credentials Database for CredScanner
# ==============================================
# This file contains default credentials for various services and protocols.
# Add your custom credentials here or create a separate file.
#
# Format:
#   protocol_name:
#     - username: "user"
#       password: "pass"
#       service: "service_name"  # Optional identifier
#       description: "Description"  # Optional
#
# Inspired by changeme: https://github.com/ztgrace/changeme

http:
  # Generic web applications
  - username: "admin"
    password: "admin"
    service: "generic"
    description: "Common default admin credentials"

  - username: "admin"
    password: "password"
    service: "generic"

  - username: "admin"
    password: ""
    service: "generic"
    description: "Admin with blank password"

  - username: "administrator"
    password: "administrator"
    service: "generic"

  - username: "root"
    password: "root"
    service: "generic"

  - username: "root"
    password: "toor"
    service: "generic"

  # Apache Tomcat
  - username: "tomcat"
    password: "tomcat"
    service: "tomcat"
    description: "Apache Tomcat default"

  - username: "admin"
    password: "tomcat"
    service: "tomcat"

  - username: "manager"
    password: "manager"
    service: "tomcat"

  - username: "tomcat"
    password: "s3cret"
    service: "tomcat"

  # Grafana
  - username: "admin"
    password: "admin"
    service: "grafana"
    description: "Grafana default credentials"

  # Jenkins
  - username: "admin"
    password: "admin"
    service: "jenkins"

  - username: "jenkins"
    password: "jenkins"
    service: "jenkins"

  # Atlassian Jira
  - username: "admin"
    password: "admin"
    service: "jira"

  # GitLab
  - username: "root"
    password: "5iveL!fe"
    service: "gitlab"
    description: "GitLab default root password"

  # RabbitMQ
  - username: "guest"
    password: "guest"
    service: "rabbitmq"

  # Elasticsearch
  - username: "elastic"
    password: "changeme"
    service: "elasticsearch"

  # Kibana
  - username: "elastic"
    password: "changeme"
    service: "kibana"

ssh:
  # Generic SSH
  - username: "root"
    password: "root"
    service: "generic"

  - username: "root"
    password: "toor"
    service: "generic"

  - username: "admin"
    password: "admin"
    service: "generic"

  - username: "administrator"
    password: "administrator"
    service: "generic"

  - username: "user"
    password: "user"
    service: "generic"

  # Raspberry Pi
  - username: "pi"
    password: "raspberry"
    service: "raspberry-pi"
    description: "Raspberry Pi default"

  # Ubuntu
  - username: "ubuntu"
    password: "ubuntu"
    service: "ubuntu"

  # Debian
  - username: "debian"
    password: "debian"
    service: "debian"

  # Cisco
  - username: "cisco"
    password: "cisco"
    service: "cisco"

  - username: "admin"
    password: "admin"
    service: "cisco"

  # VMware ESXi
  - username: "root"
    password: "vmware"
    service: "vmware-esxi"

  - username: "root"
    password: ""
    service: "vmware-esxi"

  # Ubiquiti
  - username: "ubnt"
    password: "ubnt"
    service: "ubiquiti"

ftp:
  # Anonymous FTP
  - username: "anonymous"
    password: "anonymous@"
    service: "generic"
    description: "Anonymous FTP access"

  - username: "anonymous"
    password: "guest"
    service: "generic"

  - username: "anonymous"
    password: ""
    service: "generic"

  # Generic FTP
  - username: "ftp"
    password: "ftp"
    service: "generic"

  - username: "admin"
    password: "admin"
    service: "generic"

  - username: "root"
    password: "root"
    service: "generic"

smb:
  # Guest access
  - username: "guest"
    password: ""
    service: "generic"
    description: "Guest account with no password"

  - username: ""
    password: ""
    service: "generic"
    description: "Null session"

  # Windows defaults
  - username: "administrator"
    password: "admin"
    service: "windows"

  - username: "administrator"
    password: "password"
    service: "windows"

  - username: "administrator"
    password: "Password1"
    service: "windows"

  - username: "administrator"
    password: "Password123"
    service: "windows"

  - username: "admin"
    password: "admin"
    service: "windows"

  # Common weak passwords
  - username: "administrator"
    password: ""
    service: "windows"

mysql:
  # Root without password
  - username: "root"
    password: ""
    service: "mysql"
    description: "MySQL root with no password"

  - username: "root"
    password: "root"
    service: "mysql"

  - username: "root"
    password: "password"
    service: "mysql"

  - username: "root"
    password: "toor"
    service: "mysql"

  - username: "root"
    password: "mysql"
    service: "mysql"

  - username: "admin"
    password: "admin"
    service: "mysql"

  - username: "mysql"
    password: "mysql"
    service: "mysql"

  # Common application users
  - username: "wordpress"
    password: "wordpress"
    service: "wordpress"

  - username: "joomla"
    password: "joomla"
    service: "joomla"

postgres:
  # PostgreSQL defaults
  - username: "postgres"
    password: "postgres"
    service: "postgresql"
    description: "PostgreSQL default user"

  - username: "postgres"
    password: ""
    service: "postgresql"

  - username: "postgres"
    password: "password"
    service: "postgresql"

  - username: "postgres"
    password: "admin"
    service: "postgresql"

  - username: "admin"
    password: "admin"
    service: "postgresql"

mssql:
  # SQL Server SA account
  - username: "sa"
    password: ""
    service: "mssql"
    description: "SQL Server SA with blank password"

  - username: "sa"
    password: "sa"
    service: "mssql"

  - username: "sa"
    password: "Password1"
    service: "mssql"

  - username: "sa"
    password: "Password123"
    service: "mssql"

  - username: "sa"
    password: "password"
    service: "mssql"

  - username: "admin"
    password: "admin"
    service: "mssql"

mongodb:
  # MongoDB often has no authentication by default
  - username: ""
    password: ""
    service: "mongodb"
    description: "No authentication"

  - username: "admin"
    password: "admin"
    service: "mongodb"

  - username: "root"
    password: "root"
    service: "mongodb"

  - username: "mongo"
    password: "mongo"
    service: "mongodb"

redis:
  # Redis typically has no auth or simple password
  - username: ""
    password: ""
    service: "redis"
    description: "No authentication"

  - username: ""
    password: "redis"
    service: "redis"

  - username: ""
    password: "password"
    service: "redis"

  - username: ""
    password: "admin"
    service: "redis"

snmp:
  # SNMP community strings
  - username: ""
    password: "public"
    service: "snmp"
    description: "SNMP public community string"

  - username: ""
    password: "private"
    service: "snmp"

  - username: ""
    password: "community"
    service: "snmp"

  - username: ""
    password: "admin"
    service: "snmp"

  - username: ""
    password: "manager"
    service: "snmp"

telnet:
  # Generic Telnet
  - username: "admin"
    password: "admin"
    service: "generic"

  - username: "root"
    password: "root"
    service: "generic"

  - username: "administrator"
    password: "administrator"
    service: "generic"

  # Cisco
  - username: "cisco"
    password: "cisco"
    service: "cisco"

  # Mikrotik
  - username: "admin"
    password: ""
    service: "mikrotik"
    description: "MikroTik RouterOS default"

rdp:
  # Windows RDP defaults
  - username: "administrator"
    password: "admin"
    service: "windows"
    description: "Common Windows administrator password"

  - username: "administrator"
    password: "password"
    service: "windows"

  - username: "administrator"
    password: "Password1"
    service: "windows"

  - username: "administrator"
    password: "Password123"
    service: "windows"

  - username: "administrator"
    password: ""
    service: "windows"
    description: "Blank password"

  - username: "admin"
    password: "admin"
    service: "generic"

  - username: "user"
    password: "user"
    service: "generic"

  - username: "guest"
    password: ""
    service: "windows"
    description: "Guest account"

vnc:
  # VNC typically uses only passwords (no username)
  - username: ""
    password: "password"
    service: "generic"
    description: "Common VNC password"

  - username: ""
    password: "vnc"
    service: "generic"

  - username: ""
    password: "12345678"
    service: "generic"
    description: "8 character default (VNC max length)"

  - username: ""
    password: "admin"
    service: "generic"

  - username: ""
    password: ""
    service: "generic"
    description: "No password authentication"

  - username: ""
    password: "raspberry"
    service: "raspberry-pi"
    description: "Raspberry Pi default VNC password"

  - username: ""
    password: "default"
    service: "generic"

  - username: ""
    password: "changeme"
    service: "generic"

  - username: ""
    password: "123456"
    service: "generic"

# Add more protocols and credentials as needed
